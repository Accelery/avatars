{
  "name": "functions",
  "scripts": {
    "clean": "rimraf lib",
    "prebuild": "pnpm run clean",
    "build": "tsc && copyfiles src/_lib/_img/**/* lib/_lib/_img -u 3",
    "build:watch": "tsc --watch",
    "serve": "concurrently \"pnpm run build:watch\" \"firebase emulators:start --only functions\"",
    "shell": "pnpm run build && firebase functions:shell",
    "start": "pnpm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "protobufjs", "re2"]
  },
  "main": "lib/index.js",
  "dependencies": {
    "avatars-utils": "^0.0.4",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "copyfiles": "^2.4.1",
    "firebase-functions-test": "^3.1.0",
    "firebase-tools": "^14.10.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.0.0"
  },
  "private": true
}
