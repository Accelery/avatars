{
  "name": "functions",
  "scripts": {
    "clean": "rimraf lib",
    "prebuild": "pnpm run clean",
    "build": "tsc && copyfiles src/_lib/_img/**/* lib/_lib/_img -u 3",
    "build:watch": "tsc --watch",
    "serve": "concurrently \"pnpm run build:watch\" \"firebase emulators:start --only functions\"",
    "shell": "pnpm run build && firebase functions:shell",
    "start": "pnpm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "protobufjs",
      "re2",
      "sharp"
    ]
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "firebase-functions-test": "^3.5.0",
    "firebase-tools": "^15.17.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "private": true
}
